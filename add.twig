{% include 'header.twig' %}

<h2>Add Movie</h2>

{% if message %}
    <p style="color: green;">{{ message }}</p>
{% endif %}

{% if errors is not empty %}
    <ul style="color: red;">
        {% for error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
    </ul>
{% endif %}

<form method="post">
    <label>Movie Name:</label><br>
    <input type="text" name="movie_name" value="{{ movie_name|e }}"><br><br>

    <label>Genre:</label><br>
    <input type="text" name="genre" value="{{ genre|e }}"><br><br>

    <label>Price:</label><br>
    <input type="number" step="0.01" name="price" value="{{ price|e }}"><br><br>

    <label>Date:</label><br>
    <input type="date" name="date_of_release" value="{{ date_of_release|e }}"><br><br>

    <button type="submit">Add Movie</button>
</form>

<p><a href="list_of_movie.php">Back</a></p>

{% include 'footer.twig' %}